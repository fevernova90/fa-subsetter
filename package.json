{
  "name": "fa-subsetter-v2",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.11.2",
    "@material-ui/core": "^4.7.0",
    "@material-ui/icons": "^4.5.1",
    "archiver": "^7.0.1",
    "express": "^4.22.1",
    "fontawesome-subset": "^4.6.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-redux": "^7.1.3",
    "react-scripts": "5.0.1",
    "redux": "^4.0.4",
    "redux-thunk": "^2.3.0",
    "sass": "^1.98.0",
    "sleep-ms": "^2.0.1"
  },
  "scripts": {
    "start": "concurrently \"NODE_ENV=production node ./server/server.js\" \"sleepms 1500 && open http://localhost:8080\"",
    "dev": "concurrently \"node ./server/server.js\" \"react-scripts start\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:server": "node node_modules/.bin/jest server/server.test.js --testEnvironment node",
    "eject": "react-scripts eject"
  },
  "proxy": "http://localhost:8080",
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.4.31",
    "underscore": "^1.13.8",
    "serialize-javascript": "^7.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "typescript": "^3.7.2"
  }
